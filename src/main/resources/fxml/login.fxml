<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="20"
      styleClass="login-container"
      prefWidth="400"
      prefHeight="500">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Social App" styleClass="app-title"/>
    <Label text="Welcome back" styleClass="section-header"/>

    <VBox spacing="8" maxWidth="320">
        <Label text="Email" styleClass="field-label"/>
        <TextField fx:id="emailField" promptText="you@example.com" styleClass="input-field"/>
    </VBox>

    <VBox spacing="8" maxWidth="320">
        <Label text="Password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input-field"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-text" visible="false" wrapText="true" maxWidth="320"/>

    <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
            styleClass="primary-button" maxWidth="320"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="New here?" styleClass="hint-text"/>
        <Hyperlink fx:id="registerLink" text="Create account" onAction="#handleRegister"/>
    </HBox>

</VBox>